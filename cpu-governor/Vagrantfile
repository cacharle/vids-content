Vagrant.configure("2") do |config|
  config.vm.box = "generic/ubuntu2204"
  config.vm.hostname = "cpu-governor"

  config.vm.synced_folder ".", "/vagrant"

  config.vm.provider "libvirt" do |lv|
    lv.cpus = 4
    lv.memory = 2048
    # Expose host CPU features so cpufreq drivers (acpi-cpufreq / pstate)
    # have a chance of binding inside the guest.
    lv.cpu_mode = "host-passthrough"
  end

  config.vm.provider "virtualbox" do |vb|
    vb.cpus = 4
    vb.memory = 2048
  end

  config.vm.provision "shell", inline: <<-SHELL
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y \
      linux-tools-common \
      linux-tools-generic \
      "linux-tools-$(uname -r)" \
      cpufrequtils \
      stress-ng \
      msr-tools

    # Try to bring up a cpufreq driver so /sys/.../cpufreq/ exists in the guest.
    modprobe acpi-cpufreq || true
    modprobe msr || true
  SHELL
end
